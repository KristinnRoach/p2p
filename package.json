{
  "name": "@kidlib/p2p",
  "version": "0.1.5",
  "description": "Signaling-agnostic WebRTC peer and data-channel helpers.",
  "type": "module",
  "types": "./src/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/types/index.d.ts",
      "import": "./src/index.js",
      "default": "./src/index.js"
    },
    "./config": {
      "types": "./src/types/config.d.ts",
      "import": "./src/config.js",
      "default": "./src/config.js"
    },
    "./data-channel": {
      "types": "./src/types/data-channel.d.ts",
      "import": "./src/data-channel.js",
      "default": "./src/data-channel.js"
    },
    "./ice": {
      "types": "./src/types/ice.d.ts",
      "import": "./src/ice.js",
      "default": "./src/ice.js"
    },
    "./logger": {
      "types": "./src/types/logger.d.ts",
      "import": "./src/logger.js",
      "default": "./src/logger.js"
    },
    "./peer": {
      "types": "./src/types/peer.d.ts",
      "import": "./src/peer.js",
      "default": "./src/peer.js"
    },
    "./remote-stream": {
      "types": "./src/types/remote-stream.d.ts",
      "import": "./src/remote-stream.js",
      "default": "./src/remote-stream.js"
    },
    "./room": {
      "types": "./src/types/room.d.ts",
      "import": "./src/room.js",
      "default": "./src/room.js"
    },
    "./rtt": {
      "types": "./src/types/rtt.d.ts",
      "import": "./src/rtt.js",
      "default": "./src/rtt.js"
    },
    "./sdp": {
      "types": "./src/types/sdp.d.ts",
      "import": "./src/sdp.js",
      "default": "./src/sdp.js"
    },
    "./session": {
      "types": "./src/types/session.d.ts",
      "import": "./src/session.js",
      "default": "./src/session.js"
    },
    "./signaling": {
      "types": "./src/types/signaling.d.ts",
      "import": "./src/signaling.js",
      "default": "./src/signaling.js"
    },
    "./tracks": {
      "types": "./src/types/tracks.d.ts",
      "import": "./src/tracks.js",
      "default": "./src/tracks.js"
    }
  },
  "files": [
    "src"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "webrtc",
    "peer-to-peer",
    "datachannel"
  ],
  "scripts": {
    "dev:react": "pnpm --dir examples/react dev",
    "dev:solid": "pnpm --dir examples/solid dev",
    "kill": "pkill -f vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "changeset": "EDITOR='code --wait' changeset",
    "bump": "changeset version",
    "release": "pnpm test && changeset publish"
  },
  "homepage": "https://github.com/KristinnRoach/p2p#readme",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KristinnRoach/p2p.git"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@vitest/browser-playwright": "^4.1.0",
    "playwright": "^1.57.0",
    "vitest": "^4.1.0"
  }
}
